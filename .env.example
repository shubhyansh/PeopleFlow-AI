# Copy this file to .env and fill in real values, then run `npm run dev`.
# .env is .gitignored — do not commit real keys.
#
# This file is for LOCAL DEVELOPMENT only. End users who install a packaged
# FlowDesk build configure Supabase via the in-app setup screen on first
# launch (not via .env). Only GROQ_API_KEY is read at runtime in production.

# ---- Supabase (dev only) ----
# In dev, you can pre-seed Supabase here so you don't have to type it into
# the setup screen every time. In production builds, these are ignored —
# users enter their values into the setup screen and they're saved to
# ~/Library/Application Support/FlowDesk/flowdesk-config.json (macOS) or
# %APPDATA%\FlowDesk\flowdesk-config.json (Windows).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Groq (Electron main process only) ----
# Get a key at https://console.groq.com/keys.
# This stays in the main process and is NEVER exposed to the renderer.
# End users in production drop this into a .env file inside their userData
# folder (see README) or you can ship it as part of your build.
GROQ_API_KEY=

# Optional: override the model used for AI probing in the task-creation chat.
# Default is llama-3.3-70b-versatile (fast, capable). For deeper reasoning
# consider deepseek-r1-distill-llama-70b. Browse models at
# https://console.groq.com/docs/models
GROQ_MODEL=
