# Copy this file to .env and fill in real values, then run `npm run dev` or `npm run build`.
# .env is .gitignored — do not commit real keys.

# ---- Supabase (renderer) ----
# Create a free project at https://supabase.com → Settings → API.
# These are SAFE to ship to end users — the anon key is public by design.
# Access control will be enforced via RLS policies later.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Groq (Electron main process only) ----
# Get a key at https://console.groq.com/keys.
# This stays in the main process and is NEVER exposed to the renderer.
GROQ_API_KEY=

# Optional: override the model used for AI probing in the task-creation chat.
# Default is llama-3.3-70b-versatile (fast, capable). For deeper reasoning
# consider deepseek-r1-distill-llama-70b. Browse models at
# https://console.groq.com/docs/models
GROQ_MODEL=
